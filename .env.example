# Copy this file to .env and fill in your values

# ─── Instagram OAuth ──────────────────────────────────────────────────────────
INSTAGRAM_CLIENT_ID=YOUR_INSTAGRAM_CLIENT_ID
INSTAGRAM_CLIENT_SECRET=YOUR_INSTAGRAM_CLIENT_SECRET
INSTAGRAM_REDIRECT_URI=https://localhost/oauth/instagram

# ─── TikTok OAuth ─────────────────────────────────────────────────────────────
TIKTOK_CLIENT_KEY=YOUR_TIKTOK_CLIENT_KEY
TIKTOK_CLIENT_SECRET=YOUR_TIKTOK_CLIENT_SECRET
TIKTOK_REDIRECT_URI=https://localhost:8765/oauth/tiktok

# ─── Encryption key for token storage ────────────────────────────────────────
TOKEN_ENCRYPTION_KEY=your-super-secret-encryption-key-here

# ─── YouTube OAuth ────────────────────────────────────────────────────────────
YOUTUBE_CLIENT_ID=YOUR_YOUTUBE_CLIENT_ID.apps.googleusercontent.com
YOUTUBE_CLIENT_SECRET=YOUR_YOUTUBE_CLIENT_SECRET
YOUTUBE_REDIRECT_URI=https://localhost:8765/oauth/youtube
